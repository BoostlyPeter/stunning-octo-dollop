<!DOCTYPE html>
<html lang="sv">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pipeline-analys — SvenskVent CRM</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --teal: #15cbc5;
    --teal-dark: #0ea5a0;
    --teal-light: #d1faf8;
    --purple: #7B61FF;
    --purple-light: #ede8ff;
    --bg: #f8fafc;
    --card-bg: #fff;
    --text: #1e293b;
    --text-muted: #64748b;
    --text-light: #94a3b8;
    --border: #e2e8f0;
    --green: #22c55e;
    --green-bg: #dcfce7;
    --red: #ef4444;
    --red-bg: #fee2e2;
    --chat-bg: #f8fafc;
    --chat-bubble-agent: #e8edf2;
    --chat-bubble-user: var(--teal);
    --shadow-sm: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
    --shadow-md: 0 4px 12px rgba(0,0,0,.07), 0 2px 4px rgba(0,0,0,.04);
    --shadow-lg: 0 10px 25px rgba(0,0,0,.1), 0 4px 10px rgba(0,0,0,.05);
    --shadow-glow: 0 0 20px rgba(21,203,197,.25), 0 0 40px rgba(21,203,197,.1);
    --radius: 12px;
    --radius-sm: 8px;
  }

  body {
    font-family: system-ui, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
    padding-top: 36px;
  }

  /* ── Top bar ────────────────────────────── */
  .topbar {
    background: var(--text);
    color: #fff;
    display: flex;
    align-items: center;
    padding: 0 24px;
    height: 52px;
    position: fixed;
    top: 36px; left: 0; right: 0;
    z-index: 100;
    gap: 16px;
  }
  .svs-dots{display:inline-flex;gap:3px;background:#1a1a1a;padding:3px 5px;border-radius:2px;vertical-align:middle;margin-right:6px}
  .svs-dots span{width:8px;height:8px;border-radius:50%;background:#c8a961}
  .topbar-logo {
    font-weight: 700;
    font-size: 13px;
    color: #fff;
    letter-spacing: 0.12em;
  }
  .topbar-sep { color: #475569; }
  .topbar-title { font-size: 14px; color: #cbd5e1; font-weight: 500; }
  .topbar-right { margin-left: auto; display: flex; gap: 12px; align-items: center; }
  .topbar-badge {
    background: var(--teal);
    color: var(--text);
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
  }
  .topbar-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: var(--purple);
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; color: #fff;
  }

  /* ── Dashboard grid ─────────────────────── */
  .dashboard {
    padding: 72px 24px 24px;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding-right: 40px;
  }
  @media (max-width: 1024px) {
    .dashboard { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .dashboard { grid-template-columns: 1fr; padding: 64px 12px 12px; }
  }

  /* ── Cards ──────────────────────────────── */
  .card {
    background: var(--card-bg);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border);
    padding: 20px;
    opacity: 0;
    transform: translateY(24px) scale(.97);
    transition: opacity .5s ease, transform .5s ease, box-shadow .3s ease;
    position: relative;
    overflow: hidden;
  }
  .card.visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .card:hover {
    box-shadow: var(--shadow-md);
  }
  .card-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }
  .card-icon {
    width: 32px; height: 32px;
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 15px;
  }
  .card-icon.teal { background: var(--teal-light); }
  .card-icon.purple { background: var(--purple-light); }
  .card-icon.green { background: var(--green-bg); }
  .card-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .card-span2 { grid-column: span 2; }
  .card-span3 { grid-column: span 3; }
  @media (max-width: 1024px) {
    .card-span3 { grid-column: span 2; }
  }
  @media (max-width: 640px) {
    .card-span2, .card-span3 { grid-column: span 1; }
  }

  .big-number {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -1px;
    color: var(--text);
    line-height: 1.1;
  }
  .big-subtitle {
    font-size: 13px;
    color: var(--green);
    font-weight: 600;
    margin-top: 4px;
  }
  .big-subtitle.neutral { color: var(--text-muted); }

  /* ── Placeholder cards (empty outlines) ── */
  .placeholder-card {
    background: transparent;
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 20px;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity .4s ease, transform .4s ease;
  }
  .placeholder-card.visible { opacity: 1; transform: translateY(0); }
  .placeholder-card.hidden { display: none; }
  .placeholder-label {
    font-size: 13px;
    color: var(--text-light);
    text-align: center;
  }

  /* ── SVG chart helpers ──────────────────── */
  .chart-svg { width: 100%; display: block; }

  /* Funnel animation */
  .funnel-stage {
    opacity: 0;
    transform: translateX(-30px);
  }
  .funnel-stage.animate {
    animation: funnel-in .5s ease forwards;
  }
  @keyframes funnel-in {
    to { opacity: 1; transform: translateX(0); }
  }

  /* Bar grow animation */
  .bar-grow {
    transform-origin: bottom;
    transform: scaleY(0);
  }
  .bar-grow.animate {
    animation: bar-in .6s cubic-bezier(.34,1.56,.64,1) forwards;
  }
  @keyframes bar-in {
    to { transform: scaleY(1); }
  }

  /* Horizontal bar grow */
  .hbar-grow {
    transform-origin: left;
    transform: scaleX(0);
  }
  .hbar-grow.animate {
    animation: hbar-in .7s cubic-bezier(.25,.46,.45,.94) forwards;
  }
  @keyframes hbar-in {
    to { transform: scaleX(1); }
  }

  /* Line draw animation */
  .line-draw {
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
  }
  .line-draw.animate {
    animation: draw-line 1.2s ease forwards;
  }
  @keyframes draw-line {
    to { stroke-dashoffset: 0; }
  }

  /* Area fade */
  .area-fade {
    opacity: 0;
  }
  .area-fade.animate {
    animation: fade-in .8s ease .4s forwards;
  }

  /* Donut animation */
  .donut-segment {
    stroke-dashoffset: var(--dash-full);
    transition: stroke-dashoffset 1s ease;
  }
  .donut-segment.animate {
    stroke-dashoffset: var(--dash-target);
  }

  /* Sparkline */
  .sparkline-draw {
    stroke-dasharray: 500;
    stroke-dashoffset: 500;
  }
  .sparkline-draw.animate {
    animation: draw-line .8s ease forwards;
  }
  .spark-area-fade { opacity: 0; }
  .spark-area-fade.animate { animation: fade-in .6s ease .3s forwards; }

  @keyframes fade-in {
    to { opacity: 1; }
  }

  /* ── Badge ──────────────────────────────── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 20px;
  }
  .badge.green { background: var(--green-bg); color: #16a34a; }
  .badge.red { background: var(--red-bg); color: var(--red); }

  /* ── Legend ─────────────────────────────── */
  .legend {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 12px;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-muted);
  }
  .legend-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
  }

  /* ── Insight card glow ──────────────────── */
  .card.insight {
    border: 2px solid var(--teal);
    box-shadow: var(--shadow-glow);
  }
  .card.insight:hover {
    box-shadow: var(--shadow-glow), var(--shadow-md);
  }
  .insight-rec {
    background: var(--teal-light);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    margin-top: 16px;
    font-size: 13px;
    color: var(--teal-dark);
    font-weight: 500;
  }
  .insight-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--teal);
    color: #fff;
    border: none;
    padding: 8px 18px;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    margin-top: 12px;
    transition: background .2s, transform .1s;
  }
  .insight-btn:hover { background: var(--teal-dark); }
  .insight-btn:active { transform: scale(.97); }
  .insight-btn.success {
    background: var(--green);
    pointer-events: none;
  }

  /* ── Salesperson avatars ────────────────── */
  .sp-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
  }
  .sp-row:last-child { margin-bottom: 0; }
  .sp-avatar {
    width: 34px; height: 34px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; color: #fff;
    flex-shrink: 0;
  }
  .sp-name {
    width: 110px;
    flex-shrink: 0;
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
  }
  .sp-bar-container {
    flex: 1;
    height: 26px;
    display: flex;
    border-radius: 4px;
    overflow: hidden;
  }
  .sp-bar-seg {
    height: 100%;
    transform-origin: left;
    transform: scaleX(0);
  }
  .sp-bar-seg.animate {
    animation: hbar-in .7s cubic-bezier(.25,.46,.45,.94) forwards;
  }
  .sp-value {
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    width: 60px;
    text-align: right;
    flex-shrink: 0;
  }

  /* ── Floating chat widget ───────────────── */
  .chat-fab {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 54px; height: 54px;
    border-radius: 50%;
    background: var(--teal);
    color: #fff;
    border: none;
    cursor: pointer;
    box-shadow: var(--shadow-lg);
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform .2s, background .2s;
  }
  .chat-fab:hover { transform: scale(1.08); }
  .chat-fab svg { width: 24px; height: 24px; }
  .chat-fab.hidden { display: none; }

  .chat-panel {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 350px;
    height: 420px;
    background: var(--chat-bg);
    border-radius: 16px;
    box-shadow: var(--shadow-lg);
    z-index: 200;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px) scale(.95);
    pointer-events: none;
    transition: opacity .3s ease, transform .3s ease;
  }
  .chat-panel.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: all;
  }

  .chat-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid #e2e8f0;
  }
  .chat-head-left {
    display: flex; align-items: center; gap: 10px;
  }
  .chat-head-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--green);
  }
  .chat-head-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
  }
  .chat-head-sub {
    font-size: 11px;
    color: #94a3b8;
  }
  .chat-close {
    background: none;
    border: none;
    color: #94a3b8;
    cursor: pointer;
    font-size: 18px;
    padding: 4px;
    line-height: 1;
    transition: color .2s;
  }
  .chat-close:hover { color: #fff; }

  .chat-body {
    flex: 1;
    overflow-y: auto;
    padding: 14px 14px 8px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .chat-body::-webkit-scrollbar { width: 4px; }
  .chat-body::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }

  .chat-msg {
    max-width: 82%;
    padding: 8px 12px;
    border-radius: 12px;
    font-size: 12.5px;
    line-height: 1.45;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity .3s ease, transform .3s ease;
    word-wrap: break-word;
  }
  .chat-msg.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .chat-msg.agent {
    background: var(--chat-bubble-agent);
    color: #e2e8f0;
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .chat-msg.user {
    background: var(--teal);
    color: #fff;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }

  .chat-footer {
    padding: 10px 14px;
    border-top: 1px solid #334155;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .chat-typing {
    display: flex;
    gap: 4px;
    align-items: center;
    padding: 8px 14px;
    align-self: flex-start;
    opacity: 0;
    transition: opacity .3s;
  }
  .chat-typing.visible { opacity: 1; }
  .chat-typing span {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #64748b;
    animation: typing-bounce .8s ease infinite;
  }
  .chat-typing span:nth-child(2) { animation-delay: .15s; }
  .chat-typing span:nth-child(3) { animation-delay: .3s; }
  @keyframes typing-bounce {
    0%, 60%, 100% { transform: translateY(0); }
    30% { transform: translateY(-4px); }
  }

  /* ── Bar chart labels ──────────────────── */
  .chart-label {
    font-size: 11px;
    fill: var(--text-muted);
    font-family: system-ui, 'Segoe UI', sans-serif;
  }
  .chart-value {
    font-size: 11px;
    fill: var(--text);
    font-weight: 600;
    font-family: system-ui, 'Segoe UI', sans-serif;
  }
  .chart-grid {
    stroke: #e2e8f0;
    stroke-width: 1;
  }

  /* ── Funnel labels ─────────────────────── */
  .funnel-label {
    font-size: 12px;
    fill: #fff;
    font-weight: 600;
    font-family: system-ui, 'Segoe UI', sans-serif;
  }
  .funnel-detail {
    font-size: 10px;
    fill: rgba(255,255,255,.8);
    font-family: system-ui, 'Segoe UI', sans-serif;
  }
  .funnel-pct {
    font-size: 11px;
    fill: var(--text-muted);
    font-weight: 600;
    font-family: system-ui, 'Segoe UI', sans-serif;
  }

  /* ── Insight comparison ─────────────────── */
  .insight-compare {
    display: flex;
    gap: 24px;
    margin-top: 16px;
  }
  .insight-group { flex: 1; }
  .insight-group-label {
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 6px;
    font-weight: 500;
  }
  .insight-group-val {
    font-size: 24px;
    font-weight: 800;
    color: var(--text);
  }
  .insight-group-val.good { color: var(--green); }

  /* ── Responsive chat ────────────────────── */
  @media (max-width: 640px) {
    .chat-panel { width: calc(100vw - 24px); right: 12px; bottom: 12px; }
    .chat-fab { bottom: 12px; right: 12px; }
  }
.svs-global-header{position:fixed;top:0;left:0;right:0;height:36px;background:#1a1a1a;display:flex;align-items:center;justify-content:space-between;padding:0 20px;z-index:9999;font-family:system-ui,-apple-system,sans-serif}
.svs-global-header .svs-logo-dots{display:flex;gap:4px;margin-right:8px}
.svs-global-header .svs-logo-dots span{width:8px;height:8px;border-radius:50%;background:#c8a961}
.svs-global-header .svs-left{display:flex;align-items:center}
.svs-global-header .svs-brand-text{color:#fff;font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase}
.svs-global-header .svs-right{color:#15cbc5;font-size:11px;font-weight:700}

  /* ── Step controls ──────────────────────── */
  .step-controls{position:fixed;bottom:60px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:16px;z-index:9998;background:rgba(30,41,59,0.95);padding:10px 24px;border-radius:30px;box-shadow:0 4px 20px rgba(0,0,0,0.3);backdrop-filter:blur(8px);flex-wrap:wrap;justify-content:center}
  .step-controls button{background:#15cbc5;color:#fff;border:none;padding:8px 24px;border-radius:20px;font-size:14px;font-weight:700;cursor:pointer;transition:background 0.2s}
  .step-controls button:hover{background:#0ea5a0}
  #stepCounter{color:rgba(255,255,255,0.7);font-size:13px;font-weight:300;min-width:120px}
  .step-note{width:100%;text-align:center;color:rgba(255,255,255,0.5);font-size:12px;font-style:italic;line-height:1.3;margin-top:2px}

  /* ── Voice FAB ──────────────────────────── */
  .voice-fab{position:fixed;bottom:20px;left:20px;z-index:9998;cursor:pointer}
  .voice-fab-icon{width:48px;height:48px;border-radius:50%;background:#15cbc5;display:flex;align-items:center;justify-content:center;font-size:22px;box-shadow:0 4px 16px rgba(21,203,197,0.4);transition:transform 0.2s}
  .voice-fab:hover .voice-fab-icon{transform:scale(1.1)}
  .voice-fab-tooltip{position:absolute;bottom:56px;left:0;background:#1e293b;color:#fff;padding:10px 14px;border-radius:8px;font-size:13px;line-height:1.5;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity 0.2s;box-shadow:0 4px 16px rgba(0,0,0,0.3)}
  .voice-fab.open .voice-fab-tooltip{opacity:1;pointer-events:auto}
</style>
</head>
<body>
<div class="svs-global-header"><div class="svs-left"><div class="svs-logo-dots"><span></span><span></span><span></span><span></span></div><span class="svs-brand-text">Svensk Ventilationsservice</span></div><div class="svs-right">AI-First CRM</div></div>

<!-- Top bar -->
<div class="topbar">
  <span class="topbar-logo"><span class="svs-dots"><span></span><span></span><span></span><span></span></span> SVENSK VENTILATIONSSERVICE</span>
  <span class="topbar-sep">|</span>
  <span class="topbar-title">Pipeline-analys</span>
  <div class="topbar-right">
    <span class="topbar-badge">AI-assistent aktiv</span>
    <div class="topbar-avatar">AL</div>
  </div>
</div>

<!-- Dashboard grid -->
<div class="dashboard" id="dashboard">

  <!-- Row 1 placeholders (replaced by real cards) -->
  <div class="placeholder-card visible" id="ph1"><span class="placeholder-label">Diagram laddas...</span></div>
  <div class="placeholder-card visible" id="ph2"><span class="placeholder-label">Diagram laddas...</span></div>
  <div class="placeholder-card visible" id="ph3"><span class="placeholder-label">Diagram laddas...</span></div>

  <!-- Row 2 placeholders -->
  <div class="placeholder-card visible" id="ph4"><span class="placeholder-label">V&auml;ntar p&aring; data...</span></div>
  <div class="placeholder-card visible" id="ph5"><span class="placeholder-label">V&auml;ntar p&aring; data...</span></div>
  <div class="placeholder-card visible" id="ph6"><span class="placeholder-label">V&auml;ntar p&aring; data...</span></div>

  <!-- Row 3 placeholder -->
  <div class="placeholder-card visible card-span3" id="ph7"><span class="placeholder-label">V&auml;ntar p&aring; data...</span></div>

  <!-- Row 4 placeholder -->
  <div class="placeholder-card visible card-span2" id="ph8"><span class="placeholder-label">V&auml;ntar p&aring; data...</span></div>
  <div class="placeholder-card visible" id="ph9"><span class="placeholder-label">V&auml;ntar p&aring; data...</span></div>

  <!-- ====== REAL CARDS (hidden initially) ====== -->

  <!-- Card 1: Pipeline funnel -->
  <div class="card" id="card1">
    <div class="card-header">
      <div class="card-icon teal">&#x25B3;</div>
      <span class="card-title">Pipeline-tratt</span>
    </div>
    <svg class="chart-svg" viewBox="0 0 300 220" id="funnelSvg">
      <!-- Funnel trapezoids -->
      <g class="funnel-stage" id="fs1">
        <polygon points="10,10 290,10 265,55 35,55" fill="#5ee9e4"/>
        <text x="150" y="32" text-anchor="middle" class="funnel-label">Ny</text>
        <text x="150" y="47" text-anchor="middle" class="funnel-detail">5 aff&auml;rer &mdash; 1 200k</text>
      </g>
      <g class="funnel-stage" id="fs2">
        <polygon points="35,62 265,62 240,107 60,107" fill="#15cbc5"/>
        <text x="150" y="84" text-anchor="middle" class="funnel-label">Offert skickad</text>
        <text x="150" y="99" text-anchor="middle" class="funnel-detail">4 aff&auml;rer &mdash; 980k</text>
