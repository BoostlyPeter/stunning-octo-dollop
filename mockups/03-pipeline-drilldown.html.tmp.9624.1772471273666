<script>
(function() {
  'use strict';

  // ── State ──────────────────────────────────────
  var chatOpen = false;
  var currentStep = 0;
  var totalSteps = 10;

  // ── Chat helpers ───────────────────────────────
  var chatBody = document.getElementById('chatBody');

  function addMsg(type, text) {
    var div = document.createElement('div');
    div.className = 'chat-msg ' + type;
    div.textContent = text;
    chatBody.appendChild(div);
    chatBody.scrollTop = chatBody.scrollHeight;
    requestAnimationFrame(function() {
      requestAnimationFrame(function() { div.classList.add('visible'); });
    });
  }

  // ── Dashboard card helpers ─────────────────────
  function showCard(id) {
    var el = document.getElementById(id);
    if (el) el.classList.add('visible');
  }

  function hidePlaceholder(id) {
    var el = document.getElementById(id);
    if (el) { el.classList.remove('visible'); el.classList.add('hidden'); }
  }

  function animStagger(ids, cls, stagger) {
    ids.forEach(function(id, i) {
      setTimeout(function() {
        var el = document.getElementById(id);
        if (el) el.classList.add(cls);
      }, i * stagger);
    });
  }

  function setOpacity(id, val) {
    var el = document.getElementById(id);
    if (el) el.style.opacity = val;
  }

  // ── Reset everything ───────────────────────────
  function resetAll() {
    currentStep = 0;
    updateCounter();

    // Reset chat
    chatBody.innerHTML = '';

    // Hide all real cards
    document.querySelectorAll('.card').forEach(function(c) {
      c.classList.remove('visible');
    });

    // Show all placeholders
    document.querySelectorAll('.placeholder-card').forEach(function(p) {
      p.classList.remove('hidden');
      p.classList.add('visible');
    });

    // Reset funnel
    document.querySelectorAll('.funnel-stage').forEach(function(s) { s.classList.remove('animate'); });

    // Reset sparkline
    var sparkLine = document.getElementById('sparkLine');
    var sparkArea = document.getElementById('sparkArea');
    if (sparkLine) sparkLine.classList.remove('animate');
    if (sparkArea) sparkArea.classList.remove('animate');
    setOpacity('sparkDot', '0');

    // Reset close time bars
    ['cb1','cb2','cb3','cb4'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.classList.remove('animate');
    });
    ['cv1','cv2','cv3','cv4'].forEach(function(id) { setOpacity(id, '0'); });

    // Reset quarterly bars
    ['qb1','qb2','qb3','qb4','qb5','qb6'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.classList.remove('animate');
    });

    // Reset trend
    ['trendLine','trendProj'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.classList.remove('animate');
    });
    var trendArea = document.getElementById('trendArea');
    if (trendArea) trendArea.classList.remove('animate');
    ['trendDots','trendVals'].forEach(function(id) { setOpacity(id, '0'); });

    // Reset donut
    ['doSeg1','doSeg2','doSeg3'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.classList.remove('animate');
    });
    ['donutPct','donutSub'].forEach(function(id) { setOpacity(id, '0'); });

    // Reset salesperson bars
    document.querySelectorAll('.sp-bar-seg').forEach(function(s) { s.classList.remove('animate'); });

    // Reset insight bars
    ['ib1','ib2'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) el.classList.remove('animate');
    });
    ['iv1','iv2'].forEach(function(id) { setOpacity(id, '0'); });

    // Reset book button
    var bookBtn = document.getElementById('bookBtn');
    if (bookBtn) {
      bookBtn.classList.remove('success');
      bookBtn.innerHTML = '&#x1F4C5; Boka platsbes\u00f6k';
    }

    // Close and reopen chat
    if (!chatOpen) toggleChatFn();
  }

  // ── Steps ──────────────────────────────────────
  var steps = [
    // Step 1: Chat opens, agent greets
    function() {
      if (!chatOpen) toggleChatFn();
      addMsg('agent', 'Hej Anna! Vad vill du analysera idag?');
    },
    // Step 2: User asks "Visa pipeline"
    function() {
      addMsg('user', 'Visa pipeline-\u00f6versikt');
      addMsg('agent', 'Laddar pipeline-data...');
    },
    // Step 3: Row 1 dashboard cards appear (funnel, value, close time)
    function() {
      hidePlaceholder('ph1');
      hidePlaceholder('ph2');
      hidePlaceholder('ph3');
      showCard('card1');
      animStagger(['fs1','fs2','fs3','fs4'], 'animate', 200);
      setTimeout(function() { showCard('card2'); }, 200);
      var sl = document.getElementById('sparkLine');
      var sa = document.getElementById('sparkArea');
      if (sl) setTimeout(function() { sl.classList.add('animate'); }, 300);
      if (sa) setTimeout(function() { sa.classList.add('animate'); }, 300);
      setTimeout(function() { setOpacity('sparkDot', '1'); }, 1100);
      setTimeout(function() { showCard('card3'); }, 400);
      animStagger(['cb1','cb2','cb3','cb4'], 'animate', 150);
      ['cv1','cv2','cv3','cv4'].forEach(function(id, i) {
        setTimeout(function() { setOpacity(id, '1'); }, 800 + i * 150);
      });
    },
    // Step 4: User asks "Jamfor med forra kvartalet"
    function() {
      addMsg('user', 'J\u00e4mf\u00f6r med f\u00f6rra kvartalet');
      addMsg('agent', 'Kvartalsdata och trender inladdade.');
    },
    // Step 5: Row 2 cards appear (quarterly, trends, win rate)
    function() {
      hidePlaceholder('ph4');
      hidePlaceholder('ph5');
      hidePlaceholder('ph6');
      showCard('card4');
      animStagger(['qb1','qb2','qb3','qb4','qb5','qb6'], 'animate', 120);
      setTimeout(function() { showCard('card5'); }, 300);
      var ta = document.getElementById('trendArea');
      var tl = document.getElementById('trendLine');
      var tp = document.getElementById('trendProj');
      if (ta) setTimeout(function() { ta.classList.add('animate'); }, 400);
      if (tl) setTimeout(function() { tl.classList.add('animate'); }, 400);
      if (tp) setTimeout(function() { tp.classList.add('animate'); }, 400);
      setTimeout(function() {
        setOpacity('trendDots', '1');
        setOpacity('trendVals', '1');
      }, 1200);
      setTimeout(function() { showCard('card6'); }, 500);
      ['doSeg1','doSeg2','doSeg3'].forEach(function(id, i) {
        setTimeout(function() {
          var el = document.getElementById(id);
          if (el) el.classList.add('animate');
        }, 600 + i * 200);
      });
      setTimeout(function() {
        setOpacity('donutPct', '1');
        setOpacity('donutSub', '1');
      }, 1400);
    },
    // Step 6: User asks "Visa per saljare"
    function() {
      addMsg('user', 'Visa per s\u00e4ljare');
      addMsg('agent', 'S\u00e4ljstatistik per person.');
    },
    // Step 7: Row 3 salesperson chart appears
    function() {
      hidePlaceholder('ph7');
      showCard('card7');
      var spBars = document.querySelectorAll('.sp-bar-seg');
      spBars.forEach(function(bar, i) {
        setTimeout(function() { bar.classList.add('animate'); }, 200 + i * 100);
      });
    },
    // Step 8: Agent offers AI insight
    function() {
      addMsg('agent', 'Jag ser ett m\u00f6nster: aff\u00e4rer med platsbes\u00f6k st\u00e4ngs 40% snabbare. Vill du se det?');
    },
    // Step 9: User accepts, insight card appears
    function() {
      addMsg('user', 'Ja');
      addMsg('agent', 'H\u00e4r \u00e4r insikten med rekommendation.');
      hidePlaceholder('ph8');
      hidePlaceholder('ph9');
      showCard('card8');
      setTimeout(function() {
        var ib1 = document.getElementById('ib1');
        if (ib1) ib1.classList.add('animate');
      }, 300);
      setTimeout(function() {
        var ib2 = document.getElementById('ib2');
        if (ib2) ib2.classList.add('animate');
      }, 500);
      setTimeout(function() {
        setOpacity('iv1', '1');
        setOpacity('iv2', '1');
      }, 1000);
    },
    // Step 10: Action confirmed
    function() {
      showCard('card9');
      var btn = document.getElementById('bookBtn');
      if (btn && !btn.classList.contains('success')) {
        btn.classList.add('success');
        btn.innerHTML = '&#x2705; 2 platsbes\u00f6k inbokade';
      }
      addMsg('agent', '2 platsbes\u00f6k inbokade f\u00f6r Castellum och Nordea.');
    }
  ];

  // ── Step notes ─────────────────────────────────
  var stepNotes = [
    "AI-assistenten \u00f6ppnas \u2014 redo att analysera",
    "Anv\u00e4ndaren ber om pipeline-\u00f6versikt",
    "Tratt, totalv\u00e4rde med sparkline och st\u00e4ngningstider per typ",
    "Anv\u00e4ndaren ber om kvartalsj\u00e4mf\u00f6relse",
    "Stapeldiagram, int\u00e4ktstrend och vinstkvot \u2014 allt animerat",
    "Anv\u00e4ndaren vill se per s\u00e4ljare",
    "S\u00e4ljartavla med individuella resultat",
    "AI:n erbjuder en automatisk insikt",
    "Platsbes\u00f6k korrelerar med snabbare st\u00e4ngning \u2014 data bevisar det",
    "\u00c5tg\u00e4rd utf\u00f6rd \u2014 platsbes\u00f6k bokade direkt"
  ];

  // ── Step counter ───────────────────────────────
  function updateCounter() {
    var el = document.getElementById('stepCounter');
    if (el) el.textContent = 'Steg ' + currentStep + ' / ' + totalSteps;
    document.getElementById('stepNote').textContent = stepNotes[currentStep - 1] || '';
  }

  // ── Next step ──────────────────────────────────
  function advanceStep() {
    if (currentStep >= totalSteps) return;
    steps[currentStep]();
    currentStep++;
    updateCounter();
    chatBody.scrollTop = chatBody.scrollHeight;
  }

  window.nextStep = advanceStep;

  // ── Book visits (manual click on insight button) ──
  window.bookVisits = function() {
    var btn = document.getElementById('bookBtn');
    if (!btn || btn.classList.contains('success')) return;
    btn.classList.add('success');
    btn.innerHTML = '&#x2705; 2 platsbes\u00f6k inbokade';
  };

  // ── Toggle chat ────────────────────────────────
  function toggleChatFn() {
    chatOpen = !chatOpen;
    document.getElementById('chatPanel').classList.toggle('open', chatOpen);
    document.getElementById('chatFab').classList.toggle('hidden', chatOpen);
  }

  window.toggleChat = toggleChatFn;

  // ── Keyboard navigation ────────────────────────
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowRight' || e.key === ' ' || e.key === 'Enter') {
      e.preventDefault();
      advanceStep();
    } else if (e.key === 'r' || e.key === 'R') {
      resetAll();
    }
  });

  // ── Initial state ──────────────────────────────
  updateCounter();

})();
</script>
</body>
</html>